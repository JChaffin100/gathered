rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Allowlist ─────────────────────────────────────────────────────────
    // Only these email addresses may access any part of this database.
    // Add or remove emails here to manage family access.
    function isAllowedUser() {
      return request.auth != null
        && request.auth.token.email in [
          'jodychaffin@gmail.com',
          'hchaffin00@gmail.com',
          'codyrchaffin@gmail.com',
          'bcc122006@gmail.com',
          'kjchaffin97@gmail.com'
        ];
    }

    match /users/{userId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser() && request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow read: if isAllowedUser();
      allow create: if isAllowedUser();
      allow delete: if isAllowedUser() &&
        request.auth.uid in resource.data.members &&
        resource.data.members[request.auth.uid].role == 'admin';

      allow update: if isAllowedUser() && (
        (request.auth.uid in resource.data.members && resource.data.members[request.auth.uid].role == 'admin') ||
        (request.auth.uid in request.resource.data.members && request.resource.data.members[request.auth.uid].role == 'member')
      );

      match /posts/{postId} {
        allow read, create: if isAllowedUser();
        allow update: if isAllowedUser() && (
          request.auth.uid == resource.data.authorId ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactionCounts', 'commentCount', 'lastEngagedAt'])
        );
        allow delete: if isAllowedUser() && (
          request.auth.uid == resource.data.authorId ||
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.createdBy
        );

        match /comments/{commentId} {
          allow read, create: if isAllowedUser();
          allow update, delete: if isAllowedUser() &&
            request.auth.uid == resource.data.authorId;
        }

        match /reactions/{userId} {
          allow read, write: if isAllowedUser();
        }
      }
    }
  }
}
